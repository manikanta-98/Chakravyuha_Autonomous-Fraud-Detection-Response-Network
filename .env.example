# Database Configuration
POSTGRES_PASSWORD=your-secure-password-here
DATABASE_URL=postgresql://frauduser:your-secure-password-here@db:5432/frauddetection

# Redis Configuration
REDIS_URL=redis://redis:6379

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# JWT Security
JWT_SECRET_KEY=your-super-secure-jwt-secret-key-here-minimum-32-characters

# MLflow Configuration
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_ARTIFACT_STORE_URI=s3://mlflow-artifacts/

# AWS Configuration (for S3 and EKS)
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_DEFAULT_REGION=us-east-1

# Application Configuration
ENVIRONMENT=production
LOG_LEVEL=INFO

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
WORKERS=4

# Model Configuration
MODEL_CACHE_SIZE=100
FEATURE_STORE_CACHE_TTL=3600

# Agent Configuration
AGENT_QUEUE_SIZE=1000
AGENT_TIMEOUT=30
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# Monitoring Configuration
PROMETHEUS_METRICS_ENABLED=true
METRICS_UPDATE_INTERVAL=30

# Security Configuration
CORS_ORIGINS=["http://localhost:3000", "https://yourdomain.com"]
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=60

# Feature Store Configuration
FEAST_CORE_URL=feast-core:6565
FEAST_SERVING_URL=feast-serving:6566

# External Services
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama2:7b

# Alert Configuration
ALERT_WEBHOOK_URL=https://your-alert-webhook-url
SLACK_WEBHOOK_URL=https://hooks.slack.com/your-slack-webhook

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=7

# Performance Tuning
MAX_CONNECTIONS=100
CONNECTION_TIMEOUT=30
READ_TIMEOUT=30
WRITE_TIMEOUT=30